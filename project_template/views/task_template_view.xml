<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_task_template" model="ir.actions.act_window">
        <field name="name">Task Template</field>
        <field name="res_model">task.template</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="view_task_template_form" model="ir.ui.view">
        <field name="name">Task Template Form</field>
        <field name="model">task.template</field>
        <field name="arch" type="xml">
            <form string="Project">
                <header>
                    <button name="create_task" type="object" string="Create Task"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <h1>
                                <field name="task_name"/>
                            </h1>
                        </group>
                        <group>
                        </group>
                        <group>
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="date_deadline"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>