<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_product_request" model="ir.actions.act_window">
        <field name="name">Product Request</field>
        <field name="res_model">product.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_product_request_list" model="ir.ui.view">
        <field name="name">Productsr Rquest List</field>
        <field name="model">product.request</field>
        <field name="arch" type="xml">
            <list string="Details">
                <field name="name"/>
                <field name="vendor_id"/>
                <field name="employee_id"/>
            </list>
        </field>
    </record>


    <record id="view_product_request_form" model="ir.ui.view">
        <field name="name">Product Request Form</field>
        <field name="model">product.request</field>
        <field name="arch" type="xml">
            <form string="Request Details">
                <header>
                    <button name="action_submit" type="object" class="btn-primary" string="Submit" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" class="btn-primary" string="Confirm" invisible="state != 'submit'"/>
                    <button name="action_confirm" type="object" class="btn-primary" string="Confirm" invisible="state != 'approve'"/>
                    <button name="action_reject" type="object" string="Reject" />
<!--                    <button name="pay_installments" type="object" string="Pay" invisible="state != 'ongoing'"/>-->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submit,approve,confirm"/>
                </header>
                <sheet>
<!--                    <div class="oe_button_box" name="button_box">-->
<!--                        <button name="fetch_installments" type="object" class="oe_stat_button"-->
<!--                                icon="fa-pencil-square-o">-->
<!--                            <field name="loan_line_ids" widget="statinfo" string="Installments"/>-->
<!--                        </button>-->
<!--                    </div>-->
                    <group>
                        <group>
                            <h1><field name="name"/></h1>
                        </group>
                        <group>
                        </group>
                        <group>

                            <field name="vendor_id"/>
                            <field name="order_date"/>

                        </group>
                        <group>
                            <field name="employee_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Line">
                            <field name="product_line_ids"/>
                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

</odoo>