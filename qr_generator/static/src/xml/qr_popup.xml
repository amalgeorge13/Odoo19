<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="qr_generator.QrPopup">
        <Dialog title.translate="QR Generate">

        <div class="screen h-100 bg-100">
            <form id="QrGenerateForm">
                <div class=" d-flex justify-content-between align-items-center p-3">
                    <label class="form-label label" for="text">Text</label>
                    <input type="text" class="w-75 form-control" name="text"/>
                </div>
                <div class="row">
                    <button id="generate-btn" class="btn btn-primary o-default-button col-1 m-4"
                            t-on-click="() => this.generateQR()">Generate</button>
                    <button id="reset-btn" class="btn btn-primary o-default-button col-1 m-4"
                            t-on-click="() => this.resetQR()">Reset</button>
                </div>
            </form>
       </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" id="back-btn"
                        t-on-click="() => this.closeQrPopup()">Back</button>
            </t>
        </Dialog>
    </t>
</templates>