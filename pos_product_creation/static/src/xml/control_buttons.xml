<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.SelectProductButton" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
       <xpath
            expr="//SelectPartnerButton"
            position="after">
           <button class="product-btn" t-att-class="buttonClass" t-on-click="() => this.ListProduct()"
                   t-if="!props.showRemainingButtons">
               <span>Products</span>
           </button>
       </xpath>
   </t>
</templates>

