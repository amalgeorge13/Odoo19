<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="email_budget" model="mail.template">
            <field name="name">EMAIL TEMPLATE NAME</field>
       <field name="model_id" ref="project_budget.model_project_project"/>
            <field name="subject">Limit Remainder</field>
            <field name="email_from">
                {{ user.email_formatted or user.company_id.email_formatted }}
            </field>
            <field name="partner_to">{{ object.user_id.id }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>
                        Hello,
                        <br/>
                        <br/>
                        Reached our 80% of our budget
                        <br/>
                        <br/>
                        Mitchell Admin
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>


