<?xml version='1.0' encoding='utf-8' ?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">MultiSafepay Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <widget name="web_ribbon" title="disabled" bg_color="text-bg-danger" invisible="state != 'disabled'"/>
                <widget name="web_ribbon" title="test mode" bg_color="text-bg-warning" invisible="state != 'test'"/>
            </xpath>
            <group name="provider_credentials" position='inside'>
                <group invisible="code != 'multisafepay'">

                    <field name="multisafepay_api_key"
                           string="API Key"
                           required="code == 'multisafepay' and state != 'disabled'"/>
                    <field name="redirect_form_view_id"/>

                </group>
            </group>

        </field>
    </record>

</odoo>