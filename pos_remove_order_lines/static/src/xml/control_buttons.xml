<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="clear_lines.ClearButton" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
       <xpath
            expr="//button[hasclass('more-btn')]"
            position="before">
           <button class="clear-btn" t-att-class="buttonClass" t-on-click="() => this.onClickClr()"
                   t-if="!props.showRemainingButtons" >
               <span>Clear</span>
           </button>
       </xpath>
   </t>
</templates>

