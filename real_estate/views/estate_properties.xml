<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
<!--    window action-->
    <record id="action_real_estate_properties" model="ir.actions.act_window">
        <field name="name">Real Estate</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form,kanban,pivot</field>
        <field name="context">{'search_default_available': True}</field>

    </record>

    <record id="view_real_estate_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties" decoration-success="state in ('offer_received','offer_accepted')" decoration-bf="state=='offer_accepted'" decoration-muted="state=='sold'">
                <field name="sequence" widget="handle"/>
                <field name="property_name"/>
                <field name="postcode"/>
                <field name="date_availability" optional="hide"/>
                <field name="bedrooms"/>
                <field name="living_area"/>
                <field name="property_tag_name" widget="many2many_tags" options="{'color_field':'color'}"/>
                <field name="expected_price"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_real_estate_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Properties">
                <header>
                    <button name="action_sold" class="oe_highlight" type="object" string="Sold" invisible="state in ('sold','cancelled')"/>
                    <button name="action_cancel"  type="object" string="Cancel" invisible="state in ('sold','cancelled')" />
                    <field name="state" widget="statusbar" statusbar_visible="new,offer_received,offer_accepted,sold"/>
                </header>

                <sheet>
                    <h1>
                        <field name="property_name"/>
                    </h1>
                    <field name="property_tag_name" widget="many2many_tags" options="{'color_field': 'color'}"/><br/><br/>
                    <group>
                        <group>
                            <field name="property_type_name" options="{'no_create': true}"/>
                            <field name="postcode"/>
                            <field name="date_availability"/>
                        </group>
                        <group>
                            <field name="expected_price"/>
                            <field name="best_offer"/>
                            <field name="selling_price"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <group>
                                <field name="description"/>
                                <field name="bedrooms"/>
                                <field name="living_area"/>
                                <field name="facades"/>
                                <field name="garage"/>
                                <field name="garden"/>
                                <field name="garden_area" invisible="not garden"/>
                                <field name="garden_orientation" invisible="not garden"/>
                                <field name="active"/>
                                <field name="state"/>
                                <field name="total_area"/>
                            </group>

                        </page>
                        <page string="Offers">
                            <field name="offer_ids" readonly="state in ('sold','cancelled','offer_accepted')"/>
                        </page>

                        <page string="Other Info">
                            <group>
                                <field name="user_name"/>
                                <field name="partner_name"/>
                            </group>

                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_real_estate_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search string="Test">
                <field name="property_name"/>
                <field name="postcode"/>
                <field name="expected_price"/>
                <field name="bedrooms"/>
                <field name="facades"/>
                <field name="garden_area"/>
                <field name="active"/>
                <field name="living_area"
                       filter_domain="[('living_area','>=',self)]"/>
                <filter string="Available"
                        name="available"
                        domain="[('state','=','new')]"/>
                <filter string="Archived"
                        name="inactive"
                        domain="[('active', '=', False)]"/>
                <filter string="State"
                        name="state"
                        domain="[('state','=', ['new','offer_received'])]"/>
                <filter string='Postcode'
                        name='group_postcode'
                        context="{'group_by': 'postcode'}"/>
            </search>
        </field>
    </record>

</odoo>

