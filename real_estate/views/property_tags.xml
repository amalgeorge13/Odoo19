<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="action_real_estate_property_tags" model="ir.actions.act_window">
        <field name="name">Property Tags</field>
        <field name="res_model">property.tags</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="view_property_tags_list" model="ir.ui.view">
        <field name="name">property.tags.list</field>
        <field name="model">property.tags</field>
        <field name="arch" type="xml">
            <list string="Types" editable="bottom">
                <field name="property_tag_name"/>
            </list>
        </field>
    </record>

</odoo>