<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_real_estate_property_types" model="ir.actions.act_window">
        <field name="name">Property Types</field>
        <field name="res_model">property.types</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_property_types_list" model="ir.ui.view">
        <field name="name">property.types.list</field>
        <field name="model">property.types</field>
        <field name="arch" type="xml">
            <list string="Types">
                <field name="property_type_name"/>
            </list>
        </field>
    </record>

    <record id="view_property_types_form" model="ir.ui.view">
        <field name="name">property.types.form</field>
        <field name="model">property.types</field>
        <field name="arch" type="xml">
            <form string="Types">
                <sheet>
                    <button name="%(action_type_offers)d" class="oe_stat_button" icon="fa-money" aria-hidden="true" type="action">
                    <field name="offer_count" widget="statinfo" /></button>
                    <h1>
                        <field name="property_type_name"/>

                    </h1>
                    <notebook>
                        <page string="Properties">

                            <field name="property_ids">
                                <list>
                                    <field name="property_name" string="Title"/>
                                    <field name="expected_price"/>
                                    <field name="state"/>
                                </list>
                            </field>


                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>