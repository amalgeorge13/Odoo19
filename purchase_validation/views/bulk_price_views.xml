<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="bulk_view_form" model="ir.ui.view">
        <field name="name">bulk.view.form</field>
        <field name="model">bulk.price</field>
        <field name="arch" type="xml">
            <form string="bulk">
                <group>
                    <field name="product_id"/>
                    <field name="price_based"/>
                    <field name="percentage" invisible="price_based != 'percentage'"/>
                    <field name="fixed_price" invisible="price_based != 'fixed_price'"/>
                </group>
                <footer>
                    <button name="update_price" string="Update Price" type="object" groups="sales_team.group_sale_manager"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>



</odoo>


