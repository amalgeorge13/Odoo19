<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="weather_notification.WeatherMenu">
    <Dropdown position="'bottom-end'" state="dropdown" bottomSheet="false">

        <button>
            <i class="fa fa-lg fa-cloud" role="img" aria-label="Weather"></i>
        </button>
        <t t-set-slot="content">
            <div class="card h-100 shadow-sm" style="background-color: #9fdffc;">
                <span class="fw-light" t-esc="state.today"/>
            </div>
        </t>
    </Dropdown>
</t>
</templates>