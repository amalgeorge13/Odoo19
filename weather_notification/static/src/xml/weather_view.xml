<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="weather_notification.WeatherMenu">
    <Dropdown position="'bottom-end'" state="dropdown" bottomSheet="false">

        <button>
            <i class="fa fa-lg fa-cloud" role="img" aria-label="Weather"></i>
        </button>
        <t t-set-slot="content">
            <div class="card h-100 shadow-sm"
                 t-attf-style="background-image:url('/weather_notification/static/src/weather_test.png');
                 background-size:cover;">
                <div class="m-3">
                    <span class=" bold fs-6 ml-3 mt-3" t-esc="state.today"/><br/>
                    <span class=" bold fs-1 ml-3" t-esc="state.temperature"/><br/>
                    <span class=" bold fs-4 ml-3" t-esc="state.description"/><br/>
                    <span class=" bold fs-5 ml-3" t-esc="state.place"/><br/>
                    <span class=" bold fs-6 ml-3" t-esc="state.last_update"/>
                </div>



            </div>
        </t>
    </Dropdown>
</t>
</templates>