<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">view.res.config.settings.form.inherited</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='invite_users']" position="before">
                <div id="weather">
                    <block title="Weather" name="weather_setting_container">
                        <setting id="API Key">
                            <field name="api_key"/>
                        </setting>
                        <setting id="Latitude and Longitude">
                            <field name="use_lat_long"/>
                            <field name="latitude" invisible="not use_lat_long"/><br/>
                            <field name="longitude" invisible="not use_lat_long"/>

                        </setting>
                    </block>
                </div>
            </xpath>
        </field>
    </record>
</odoo>