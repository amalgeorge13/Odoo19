<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="action_mrp_production" model="ir.actions.act_window">
        <field name="name">Mrp Production</field>
        <field name="res_model">mrp.production.ext</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_mrp_production_ext_list" model="ir.ui.view">
        <field name="name">Mrp Production List</field>
        <field name="model">mrp.production.ext</field>
        <field name="arch" type="xml">
            <list string="Details">
                <field name="name"/>
                <field name="bom_id"/>
                <field name="quantity"/>
                <field name="state"/>
            </list>
        </field>
    </record>


    <record id="view_mrp_production_ext_form" model="ir.ui.view">
        <field name="name">Mrp Production Form</field>
        <field name="model">mrp.production.ext</field>
        <field name="arch" type="xml">
            <form string="Manufacturing Details">
                <header>
                    <button name="action_confirm" type="object" string="Confirm Production" invisible="state != 'draft'"/>
                    <button name="action_start_production" type="object" string="Start Production" invisible="state != 'confirmed'"/>
                    <button name="action_partial_production" type="object" string="Partial Production" invisible="state != 'confirmed'"/>
                    <button name="action_consume_materials" type="object" string="Consume Materials" invisible="state != 'in_progress'"/>
                    <button name="action_done" type="object" string="Done" invisible="state != 'in_progress'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="fetch_materials" type="object" class="oe_stat_button"
                                icon="fa-pencil-square-o">
                            <field name="material_line_ids" widget="statinfo" string="Materials"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <h1>
                                <field name="name"/>
                            </h1>
                        </group>
                        <group>
                        </group>
                        <group>

                            <field name="product_id"/>
                            <field name="bom_id"/>
                            <field name="available"/>

                        </group>
                        <group>

                            <field name="quantity"/>
                            <field name="planned_date"/>
                            <field name="produced_qty"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Materials">
                            <field name="material_line_ids"/>
                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

</odoo>