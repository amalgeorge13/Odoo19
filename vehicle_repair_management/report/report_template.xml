<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="vehicle_repair_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <h2>Repair Report</h2>

                <t t-if="len(customer) == 1">
                    <p>Customer Name:
                        <t t-esc="customer[0]"/>
                    </p>
                </t>

                <t t-if="len(advisor) == 1">
                    <p>User Name:
                        <t t-esc="advisor[0]"/>
                    </p>
                </t>

                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Reference No</th>
                            <t t-if="len(customer) != 1">
                                <th>Customer</th>
                            </t>
                            <t t-if="len(advisor) != 1">
                                <th>Service Advisor</th>
                            </t>
                            <th>Start Date</th>
                            <th>Delivery Date</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-foreach="docs" t-as="rec">
                            <tr>
                                <td>
                                    <t t-esc="rec[0]"/>
                                </td>
                                <t t-if="len(customer) != 1">
                                    <td>
                                        <t t-esc="rec[1]"/>
                                    </td>
                                </t>

                                <t t-if="len(advisor) != 1">
                                    <td>
                                        <t t-esc="rec[2]"/>
                                    </td>
                                </t>

                                <td>
                                    <t t-esc="rec[3]"/>
                                </td>
                                <td>
                                    <t t-esc="rec[4]"/>
                                </td>
                            </tr>
                        </t>


                    </tbody>
                </table>
            </t>
        </t>
    </template>
</odoo>

