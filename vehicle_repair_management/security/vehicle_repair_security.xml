<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record model="res.groups.privilege" id="res_groups_privilege_vr">
        <field name="name">VR</field>
        <field name="sequence">1</field>
        <field name="category_id" ref="base.module_category_services"/>
    </record>

    <record id="group_vehicle_repair_manager" model="res.groups">
        <field name="name">Vehicle Repair Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_vr"/>
    </record>


    <record id="group_vehicle_repair_technician" model="res.groups">
        <field name="name">Vehicle Repair Technician</field>
        <field name="privilege_id" ref="res_groups_privilege_vr"/>
    </record>

    <record id="technician_rule_portal" model="ir.rule">
        <field name="name">Portal Technician</field>
        <field name="model_id" ref="vehicle_repair_management.model_vehicle_repair"/>
        <field name="domain_force">[('service_advisor','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('vehicle_repair_management.group_vehicle_repair_technician'))]"/>
    </record>

    <record model="ir.rule" id="vehicle_repair_comp_rule">
        <field name="name">Vehicle Repair-company</field>
        <field name="model_id" ref="vehicle_repair_management.model_vehicle_repair"/>
        <field name="domain_force">[('company_id', '=', company_ids)]</field>
    </record>


</odoo>
