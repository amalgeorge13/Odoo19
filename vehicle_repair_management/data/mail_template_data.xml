<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="email_template_vehicle_delivery" model="mail.template">
            <field name="name">Ready For Delivery</field>
       <field name="model_id" ref="vehicle_repair_management.model_vehicle_repair"/>
            <field name="subject">Ready For Delivery {{ object.customer_name.name }}</field>
            <field name="email_from">
                {{ user.email_formatted }}
            </field>
            <field name="email_to">{{ object.customer_name.email }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>
                        Hello,
                        <br/>
                        <br/>
                        Your vehicle now ready for delivery
                        <br/>
                        Total Labor cost : ₹<t t-out="object.labor_total_amount">xx.xx</t>
                        <br/>
                        Total Parts cost : ₹<t t-out="object.parts_total_amount">xx.xx</t>
                        <br/>
                        Total Amount : ₹<t t-out="object.total_amount">xx.xx</t>
                        <br/>
                        <br/>
                        Mitchell Admin
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>

