<?xml version="1.0" encoding="utf-8"?>
<odoo>

     <template id="portal_my_home_repair" name="Repair Orders" customize_show="True" inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]">

            <div id="portal_repair_category">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/fleet/static/description/icon.svg'"/>
                <t t-set="title">Your Repair Orders</t>
                <t t-set="url" t-value="'/my/repair_orders'"/>
                <t t-set="text">Follow, View Your Repair Orders</t>
                <t t-set="placeholder_count" t-value="'order_count'"/>
            </t>
        </div>

        </xpath>

    </template>

<template id="portal_my_repair_orders" name="My Repair Orders">
        <t t-call="portal.portal_layout">
           <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Your Repair Orders</t>
            </t>
            <div t-if="not repairs" class="alert alert-warning" role="alert">
                There are currently no repair orders for your account.
            </div>
            <t t-if="repairs" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Repair Reference</th>
                        <th class="text-end">Start Date</th>
                        <th name="order_total" class="text-end">Total</th>
                    </tr>
                </thead>
                <t t-foreach="repairs" t-as="repair">
                    <tr>
                        <td><a t-attf-href="/repair_details/{{repair['id']}}"><t t-out="repair['repair_reference']"/></a></td>
                        <td class="text-end"><t t-out="repair['start_date']" t-options="{'widget': 'date'}"/></td>
                        <td class="text-end"><t t-out="repair['total_amount']"/></td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <template id="portal_my_repair_details" name="Repair Record">
        <t t-call="portal.portal_layout">
           <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Repair Record</t>
            </t>
            <div class="row">
                <div class="col-md-8"><h2>Repair Reference : <em><t t-out="repair_record.display_name"/></em></h2><br/><br/><br/></div>
                <t t-if="repair_record.image">
                    <div class="col-md-4">
                        <img t-attf-src="data:image/png;base64,{{repair_record['image']}}"
                                 class="img img-fluid rotate-center " style="width: 100; height: 75;"
                                 loading="lazy"/>
                    </div></t>
                <t t-else="">
                        <img class="img img-fluid rotate-center"
                             src="/vehicle_repair_management/static/src/image.png"
                             style="width: 300px; height: 200px ;"/></t>
            </div>

            <div>
                <div class="row">
                  <div class="col-md-6">Service Advisor : <t t-out="repair_record.service_advisor.name"/><br/></div>
                  <div class="col-md-6">Start Date : <t t-out="repair_record.start_date"/><br/></div>
                </div>
                <div class="row">
                  <div class="col-md-6">Vehicle Type : <t t-out="repair_record.vehicle_type.name"/><br/></div>
                  <div class="col-md-6">Status : <t t-out="repair_record.state"/></div>
                </div>


                    Vehicle Model : <t t-out="repair_record.vehicle_model.name"/><br/>
                    Vehicle Number : <t t-out="repair_record.vehicle_number"/><br/>


            </div>

        </t>
    </template>
</odoo>


