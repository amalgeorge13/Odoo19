<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_partners_form_repair" model="ir.ui.view">
        <field name="name">view.res.partner.form.repair.inherited</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_get_vehicles_repair_record" type="object" icon="fa-car">
                    <field string="Vehicles" name="vehicle_ids" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="after">
                <header>
                    <button name="action_create_repair_record" string="repair" type="object" class="oe_highlight"/>
                    <field name="customer_state" widget="statusbar" statusbar_visible="non_service_customer,service_customer"/>
                </header>
            </xpath>
        </field>
    </record>







</odoo>


