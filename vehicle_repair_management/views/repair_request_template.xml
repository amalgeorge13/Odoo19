<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!-- Repair Request Form Template -->
        <template id="repair_request_form_template" name="Repair Request Form">
            <t t-call="website.layout">
                <section class="d-flex align-items-center justify-content-center vh-100"
                         style="background-color: #f8f9fa;">
                    <div class="card shadow-lg rounded-4" style="width: 400px;">
                        <div class="card-body p-5">
                            <h3 class="text-center mb-4">Create Repair Request</h3>
                            <form action="repair_request_form" method="post">
                                <div class="form-group col-12">
                                    <label for="partner">Name</label>
                                    <select name="partners" class="form-control s_website_form_input">
                                        <option value="">Select</option>
                                        <t t-foreach="partners" t-as="partner">
                                            <option t-att-value="partner.id">
                                                <t t-esc="partner.display_name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="form-group col-12">
                                    <label for="adviser">Adviser</label>
                                    <select name="users" class="form-control s_website_form_input">
                                        <option value="">Select</option>
                                        <t t-foreach="users" t-as="user">
                                            <option t-att-value="user.id">
                                                <t t-esc="user.display_name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="form-group col-12">
                                    <label for="vehicle_type">Vehicle Type</label>
                                    <select name="vehicle_types" class="form-control s_website_form_input">
                                        <option value="">Select</option>
                                        <t t-foreach="vehicle_types" t-as="vehicle_type">
                                            <option t-att-value="vehicle_type.id">
                                                <t t-esc="vehicle_type.display_name"/>
                                            </option>
                                        </t>
                                    </select>

                                </div>
                                <div class="form-group col-12">
                                    <label for="vehicle_model">Vehicle Model</label>
                                    <select name="vehicle_models" class="form-control s_website_form_input">
                                        <option value="">Select</option>
                                        <t t-foreach="vehicle_models" t-as="vehicle_model">
                                            <option t-att-value="vehicle_model.id">
                                                <t t-esc="vehicle_model.display_name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="form-group col-12">
                                    <label for="email">Email</label>
                                    <input type="email" class="form-control"
                                           name="email"
                                           placeholder="Enter your mail-id"
                                           required="required"/>
                                </div>
                                <div class="form-group col-12">
                                    <label for="vehicle_number">Vehicle Number</label>
                                    <input type="text"
                                           class="form-control"
                                           name="vehicle_number"
                                           placeholder="Enter Vehicle Number"
                                           required="required"/>
                                </div>
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary btn-block rounded-3 py-2">
                                        Submit
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </section>
            </t>
        </template>
        <!-- Success Page -->
        <template id="customer_success_template" name="Customer Created">
            <t t-call="website.layout">
                <section class="d-flex align-items-center justify-content-center vh-100"
                         style="background-color: #f8f9fa;">
                    <div class="text-center">
                        <h3 class="text-success mb-3">Repair Request Created Successfully!</h3>
                        <a href="/repair_request" class="btn btn-primary rounded-3">Add Another Request</a>
                    </div>
                </section>
            </t>
        </template>

        <!--single repair website form-->
        <template id="repair_details_template" name="Repair">

            <t t-call="website.layout">

                <div class="text-left">
                    <a href="/" class="btn btn-primary rounded-3">Back</a>
                </div>

                <section class=" vh-100 container"
                         style="background-color: #f8f9fa; padding:6%">
                    <div class=" row border border-dark-subtle" style="background-color: #ffffff;">

                    <div class="img_wrapper col text-left ">

                        <t t-if="repair and repair['image']">
                            <img t-attf-src="data:image/png;base64,{{repair['image']}}"
                                 class="img img-fluid rotate-center " style="width: 400px; height: 400px;"
                                 loading="lazy"/>
                        </t>

                        <t t-else="">
                            <img src="/vehicle_repair_management/static/src/image.png"
                                 class="img img-fluid rotate-center" style="width: 400px; height: 400px;"
                                 loading="lazy"/>
                        </t>

                    </div>
                    <div class="col" style="margin-top:5%">
                        <p><h1><t t-esc="repair['repair_reference']"/></h1></p>
                        <p><strong>Customer : </strong><t t-esc="repair['customer_name'][1]"/></p>
                        <p><strong>Service Adviser : </strong><t t-esc="repair['service_advisor'][1]"/></p>
                        <p><strong>Vehicle Number : </strong><t t-esc="repair['vehicle_number']"/></p>
                    </div>
                    </div>
                </section>

            </t>
        </template>


    </data>

    </odoo>
