<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="action_consumed_parts" model="ir.actions.act_window">
        <field name="name">Consumed Parts</field>
        <field name="res_model">consumed.parts</field>
        <field name="view_mode">list</field>
    </record>

    <record id="view_consumed_parts_list" model="ir.ui.view">
        <field name="name">consumed.parts.list</field>
        <field name="model">consumed.parts</field>
        <field name="arch" type="xml">
            <list string="Consumed Parts" editable="bottom">
                <field name="reference" optional="hide"/>
                <field name="part_id"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

</odoo>