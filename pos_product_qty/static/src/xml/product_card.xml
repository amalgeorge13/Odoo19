<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
   <t t-name="custom_pos_receipt.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
       <xpath expr="//div[hasclass('product-content')]" position="after">
           <span>
                   <div>Available Qty:
<!--                       <t t-log="this.props.product"/>-->
<!--                       <t t-log="this.props.product.property_stock_inventory"/>-->
                       <t t-if="this.props.product.qty_available > 0">
                    <span t-esc="this.props.product.qty_available" />
                       </t>
                       <t t-else="">
                           0
                       </t>
                   </div>
           </span>
       </xpath>
   </t>
</templates>
