<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="action_travel_agency_booking" model="ir.actions.act_window">
        <field name="name">Travel Agency</field>
        <field name="res_model">travel.agency</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_booking_list" model="ir.ui.view">
        <field name="name">travel.agency.booking.list</field>
        <field name="model">travel.agency</field>
        <field name="arch" type="xml">
            <list string="Booking" decoration-success="state in ('booked')">
                <field name="customer_name"/>
                <field name="no_of_people"/>
                <field name="vehicle"/>
                <field name="date"/>
            </list>
        </field>
    </record>
    <record id="view_booking_form" model="ir.ui.view">
        <field name="name">travel.agency.booking.form</field>
        <field name="model">travel.agency</field>
        <field name="arch" type="xml">
            <form string="Booking">
                <header>
                    <button name="action_booked" class="oe_highlight" type="object" string="Book" invisible="state in ('booked','cancelled')"/>
                    <button name="action_cancelled" type="object" string="Cancel" invisible="state in ('booked','cancelled')"/>
                    <button name="action_reschedule" class="oe_highlight" type="object" string="Reschedule" invisible="state in ('new','cancelled','ongoing')" />
                    <button name="create_invoice" class="oe_highlight" type="object" string="Create Invoice" invisible="state in ('new','cancelled','ongoing')" />
                    <field name="state" widget="statusbar" statusbar_visible="new,ongoing,booked"/>
                </header>
                <sheet>
                    <h1>
                        <field name="customer_name"/>
                    </h1>
                    <group>
                        <group>+

                            <field name="age" readonly="state in ('booked')"/>
                            <field name="no_of_people" readonly="state in ('booked')"/>
                            <field name="vehicle" readonly="state in ('booked')"/>
                            <field name="date" readonly="state in ('booked')"/>
                            <field name="no_of_days" readonly="state in ('booked')"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="from_city" readonly="state in ('booked')"/>
                            <field name="to_city" readonly="state in ('booked')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Expenses" invisible ="state in ('booked','cancelled','ongoing')">
                            <group>
                                <field name="driver_fare"/>
                                <field name="petrol_expense"/>
                                <field name="room"/>
                                <field name="room_expense" invisible="not room"/>
                                <field name="food"/>
                                <field name="food_expense" invisible="not food"/>
                            </group>

                        </page>
                        <page  string="Valuation" invisible ="state in ('new','cancelled','ongoing')">
                            <group>
                                <field name="driver_fare" readonly="true"/>
                                <field name="petrol_expense" readonly="true"/>
                                <field name="room_expense" invisible="not room" readonly="true"/>
                                <field name="food_expense" invisible="not food" readonly="true"/>
                                <field name="total_expense"/>
                            </group>

                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>



    <record id="action_invoice" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">vehicles</field>
