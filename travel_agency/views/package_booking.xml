    <record id="view_booking_reschedule_form" model="ir.ui.view">
        <field name="name">booking.reschedule.form</field>
        <field name="model">booking.reschedule</field>
        <field name="arch" type="xml">
            <form string="Booking Reschedule">

                <header>

                </header>
                <sheet>
                    <h1>
                        <field name="booking_id"/>
                    </h1>

                    <group>
                        <field name="customer_name"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <button name="action_confirm_reschedule" class="oe_highlight" type="object" string="Confirm"></button>
                </sheet>
            </form>
        </field>
    </record>
</odoo>