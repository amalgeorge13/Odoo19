<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
        <record id="action_packages" model="ir.actions.act_window">
        <field name="name">Packages</field>
        <field name="res_model">packages</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="view_package_list" model="ir.ui.view">
        <field name="name">package.list</field>
        <field name="model">packages</field>
        <field name="arch" type="xml">
            <list string="Packages">
                <field name="package_name"/>
                <field name="from_city"/>
                <field name="to_city"/>
                <field name="no_days"/>
                <field name="price"/>
            </list>
        </field>
    </record>

    <record id="view_packages_form" model="ir.ui.view">
        <field name="name">packages.form</field>
        <field name="model">packages</field>
        <field name="arch" type="xml">
            <form string="Packages">
                <sheet>
                    <h1>
                    <field name="package_name"/>
                    </h1>
                    <group>
                        <field name="from_city"/>
                        <field name="to_city"/>
                        <field name="no_days"/>
                        <field name="price"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_package_booking" model="ir.actions.act_window">
        <field name="name">Package Booking</field>
        <field name="res_model">package.booking</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_package_booking_list" model="ir.ui.view">
        <field name="name">package.booking.list</field>
        <field name="model">package.booking</field>
        <field name="arch" type="xml">
            <list string="Packages" decoration-danger="state in ('cancelled')">
                <field name="booking_id"/>
                <field name="customer_name"/>
                <field name="package_name"/>
                <field name="no_of_people"/>
                <field name="state"/>

            </list>
        </field>
    </record>
    <record id="view_package_booking_form" model="ir.ui.view">
        <field name="name">package.booking.form</field>
        <field name="model">package.booking</field>
        <field name="arch" type="xml">
            <form string="Package Booking">

                <header>
                    <button name="package_invoice" class="oe_highlight" type="object" string="Invoice" invisible="state in ('new','cancelled')" />
                    <button name="action_reschedule" class="oe_highlight" type="object" string="Reschedule" invisible="state in ('new','cancelled')"/>
                    <button name="action_book" class="oe_highlight" type="object" string="Book" invisible="state in ('booked','cancelled')"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('booked','cancelled')" />
                    <field name="state" widget="statusbar" statusbar_visible="new,booked,cancelled"/>
                </header>
                <sheet>
                    <h1>
                        <field name="booking_id"/>
                    </h1>

                    <group>
                        <field name="customer_name"/>
                        <field name="date"/>
                        <field name="package_name"/>
                        <field name="no_of_people"/>
                        <field name="total_price"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_booking_reschedule" model="ir.actions.act_window">
        <field name="name">Booking Reschedule</field>
        <field name="res_model">booking.reschedule</field>
        <field name="view_mode">list,form</field>
    </record>

