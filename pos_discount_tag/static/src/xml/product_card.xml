<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
   <t t-name="custom_pos_receipt.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
       <xpath expr="//div[hasclass('product-img')]" position="before">
           <span>
               <t t-if="this.props.product.discount_tag_id">
                <span>
                      <div style="text-align: end;">
                          <span t-esc="this.props.product.discount_tag_id?.name" />%
                      </div>
                </span>
               </t>
           </span>
       </xpath>
   </t>
</templates>
