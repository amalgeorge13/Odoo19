<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_fleet_service_order" model="ir.actions.act_window">
        <field name="name">Fleet Service</field>
        <field name="res_model">fleet.service.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_fleet_service_list" model="ir.ui.view">
        <field name="name">Fleet Service List</field>
        <field name="model">fleet.service.order</field>
        <field name="arch" type="xml">
            <list string="Details">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="technician_id"/>
                <field name="service_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>


    <record id="view_fleet_service_form" model="ir.ui.view">
        <field name="name">Fleet Service Form</field>
        <field name="model">fleet.service.order</field>
        <field name="arch" type="xml">
            <form string="Vehicle Details">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" invisible="state != 'draft'"/>
                    <button name="action_start" type="object" string="Start" invisible="state != 'confirmed'"/>
                    <button name="action_generate_checklist" type="object" string="Generate" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ['done', 'cancelled']"/>


                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>
                <sheet>

                    <group>
                        <group>
                            <h1><field name="name"/></h1>
                        </group>
                        <group>
                        </group>
                        <group>

                            <field name="vehicle_id"/>
                            <field name="technician_id"/>
                            <field name="service_date"/>
                            <field name="type_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                             <field name="parts_total"/>
                            <field name="labour_cost"/>
                            <field name="grand_total"/>
                            <field name="checklist_progress"/>



                        </group>
                    </group>
                    <notebook>
                        <page string="Parts">
                            <field name="part_ids"/>
                        </page>
                        <page string="Check List" editable="bottom">
                            <field name="checklist_ids"/>
                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>


    <record id="view_part_list" model="ir.ui.view">
        <field name="name">Part List</field>
        <field name="model">fleet.service.order.part</field>
        <field name="arch" type="xml">
            <list string="Part" editable="bottom">
                <field name="order_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="unit_price"/>
            </list>
        </field>
    </record>

    <record id="view_checklist_list" model="ir.ui.view">
        <field name="name">Checklist</field>
        <field name="model">fleet.service.order.checklist</field>
        <field name="arch" type="xml">
            <list string="checklist" editable="bottom">
                <field name="order_id"/>
                <field name="task_name"/>
                <field name="is_done"/>
                <field name="note"/>
            </list>
        </field>
    </record>


</odoo>