<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="po_wizard_form" model="ir.ui.view">
        <field name="name">po.wizard.form</field>
        <field name="model">purchase.order.wizard</field>
        <field name="arch" type="xml">
            <form string="bulk">
                <group>
                    <field name="product_id"/>
                    <field name="partner_id"/>
                    <field name="quantity"/>
                    <field name="price"/>
                </group>
                <footer>
                    <button name="confirm_po" string="Confirm" type="object"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>



</odoo>